# Cognito configuration (baked into static build)
NEXT_PUBLIC_COGNITO_REGION=us-west-2
NEXT_PUBLIC_COGNITO_USER_POOL_ID=your-user-pool-id
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=your-client-id
NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID=your-identity-pool-id

# API Gateway URL for text chat
NEXT_PUBLIC_API_GATEWAY_URL=https://bedrock-agentcore.us-west-2.amazonaws.com/runtimes/your-runtime-arn/invocations?qualifier=DEFAULT

# Voice runtime ARN for client-side SigV4 signing
NEXT_PUBLIC_VOICE_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-west-2:123456789012:runtime/your-voice-runtime-id
NEXT_PUBLIC_AWS_REGION=us-west-2

# Media files
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=your-distribution-id.cloudfront.net
NEXT_PUBLIC_MEDIA_BUCKET=your-media-bucket-name
NEXT_PUBLIC_MEDIA_BUCKET_REGION=us-west-2

# Knowledge Base (for browser-side KB sync via Cognito Identity Pool creds)
NEXT_PUBLIC_KB_ID=your-knowledge-base-id
NEXT_PUBLIC_KB_DATA_SOURCE_ID=your-data-source-id

# Server-side only (for local dev API routes)
AWS_REGION=us-west-2
ENV=dev
USE_RUNTIME=true

# E2E test credentials (only needed for Playwright tests)
# E2E_TEST_EMAIL=your-test-user@example.com
# E2E_TEST_PASSWORD=your-test-password
